#!/usr/bin/env sh

# Kamal a veces solo aplica `network-alias: rails-app` (config/deploy.yml) a
# la red "kamal" y no a "docker-lab_proxy-network", dejando al túnel de
# Cloudflare sin forma de resolver el contenedor nuevo → 502 aunque el
# healthcheck de Kamal haya pasado (visto dos veces en producción, julio
# 2026: deploys de PR #18 y PR #21). Este hook lo detecta y corrige solo,
# sin esperar a que alguien note el 502.
#
# Variables disponibles: KAMAL_HOSTS, KAMAL_VERSION, KAMAL_PERFORMER,
# KAMAL_DESTINATION, KAMAL_RUNTIME, KAMAL_RECORDED_AT.

set -eu

SERVICE="advance_fitness_app"
ROLE="web"
NETWORK="docker-lab_proxy-network"
ALIAS="rails-app"
SSH_USER="ynt"
CONTAINER="${SERVICE}-${ROLE}-${KAMAL_VERSION}"

for HOST in $KAMAL_HOSTS; do
  echo "post-deploy: verificando alias de red '$ALIAS' en $NETWORK para $CONTAINER en $HOST..."

  ALIASES=$(ssh "${SSH_USER}@${HOST}" \
    "docker inspect ${CONTAINER} --format '{{json (index .NetworkSettings.Networks \"${NETWORK}\").Aliases}}' 2>/dev/null" || echo "null")

  case "$ALIASES" in
    *"$ALIAS"*)
      echo "post-deploy: alias OK, nada que hacer."
      ;;
    *)
      echo "post-deploy: alias ausente en $NETWORK, reconectando..."
      ssh "${SSH_USER}@${HOST}" \
        "docker network disconnect ${NETWORK} ${CONTAINER} && docker network connect --alias ${ALIAS} ${NETWORK} ${CONTAINER}"
      echo "post-deploy: alias reconectado."
      ;;
  esac

  # El entrypoint (bin/rails db:prepare, antes de arrancar Puma) se ha
  # quedado colgado en un arranque en frío varias veces seguidas (julio
  # 2026: deploys de la v1.0.0/v1.0.1), sin logs y sin abrir el puerto 80 —
  # Kamal ya había reportado el contenedor como "healthy" (solo mira
  # docker ps, no si el server realmente responde) así que el 502 solo se
  # nota después. Un `docker restart` simple siempre lo destrabó. Este
  # bloque espera a que /up responda de verdad y, si no lo hace, reinicia
  # el contenedor una vez.
  echo "post-deploy: verificando que $CONTAINER responda en /up..."
  LISTO=""
  i=0
  while [ "$i" -lt 10 ]; do
    CODIGO=$(ssh "${SSH_USER}@${HOST}" \
      "docker exec ${CONTAINER} curl -s -o /dev/null -w '%{http_code}' http://localhost:80/up" 2>/dev/null || echo "000")
    if [ "$CODIGO" = "200" ]; then
      LISTO="1"
      break
    fi
    i=$((i + 1))
    sleep 3
  done

  if [ -z "$LISTO" ]; then
    echo "post-deploy: $CONTAINER no respondió en /up tras 30s (probable cuelgue en db:prepare), reiniciando..."
    ssh "${SSH_USER}@${HOST}" "docker restart ${CONTAINER}"
    sleep 10
    CODIGO=$(ssh "${SSH_USER}@${HOST}" \
      "docker exec ${CONTAINER} curl -s -o /dev/null -w '%{http_code}' http://localhost:80/up" 2>/dev/null || echo "000")
    if [ "$CODIGO" = "200" ]; then
      echo "post-deploy: recuperado tras el reinicio."
    else
      echo "post-deploy: sigue sin responder tras el reinicio, revisar manualmente."
    fi
  else
    echo "post-deploy: /up OK, nada que reiniciar."
  fi
done
