<% content_for :title, "Mediciones — Advance Fitness" %>

<%= render "shared/encabezado",
      eyebrow: "Antropometría",
      titulo: "Mediciones de #{nombre_visible(@miembro)}",
      descripcion: "Historial de medidas tomadas en el gimnasio.",
      accion: link_to("Nueva medición", new_admin_user_medicion_path(@miembro), class: "btn btn-primary btn-sm font-bold") %>

<div class="mx-auto -mt-8 w-full max-w-4xl px-4 pb-12">
  <div class="card animate-fade-up border border-base-300 bg-base-100 shadow-md">
    <div class="card-body">
      <% if @mediciones.any? %>
        <div class="overflow-x-auto">
          <table class="table table-sm">
            <thead>
              <tr class="text-xs uppercase tracking-wider text-steel-3">
                <th>Fecha</th><th>Peso</th><th>IMC</th><th>Grasa</th><th>Cintura</th><th>Tomada por</th><th></th>
              </tr>
            </thead>
            <tbody>
              <% @mediciones.each do |medicion| %>
                <tr class="hover:bg-base-200">
                  <td class="font-medium"><%= l medicion.fecha %></td>
                  <td><%= medicion.peso_kg %> kg</td>
                  <td><%= medicion.imc || "—" %></td>
                  <td><%= medicion.grasa_pct ? "#{medicion.grasa_pct}%" : "—" %></td>
                  <td><%= medicion.cintura_cm ? "#{medicion.cintura_cm} cm" : "—" %></td>
                  <td class="text-steel-3"><%= medicion.tomada_por ? nombre_visible(medicion.tomada_por) : "el miembro" %></td>
                  <td class="text-right"><%= link_to "Editar", edit_admin_user_medicion_path(@miembro, medicion), class: "btn btn-ghost btn-xs" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="flex flex-col items-center gap-2 rounded-xl bg-base-200 py-10 text-center">
          <%= render "shared/icono", nombre: :actividad, clase: "size-8 text-steel-1" %>
          <p class="text-sm text-steel-3">Aún no hay mediciones para este miembro.</p>
          <%= link_to "Tomar la primera", new_admin_user_medicion_path(@miembro), class: "btn btn-primary btn-sm font-bold" %>
        </div>
      <% end %>

      <%= link_to "← Volver al miembro", admin_user_path(@miembro), class: "btn btn-ghost btn-sm mt-2 self-start" %>
    </div>
  </div>
</div>
