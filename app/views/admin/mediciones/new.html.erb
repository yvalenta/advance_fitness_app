<% content_for :title, "Nueva medición — Advance Fitness" %>

<%= render "shared/encabezado",
      eyebrow: "Antropometría",
      titulo: "Nueva medición de #{nombre_visible(@miembro)}",
      descripcion: "Perímetros, diámetros y pliegues. Alimenta el análisis del plan y la tendencia de progreso." %>

<div class="mx-auto -mt-8 w-full max-w-3xl px-4 pb-12">
  <div class="card animate-fade-up border border-base-300 bg-base-100 shadow-md">
    <div class="card-body">
      <%# @medicion puede venir de find_or_initialize_by y estar persistida %>
      <%# (edición same-day) — la fecha siempre se corrige por create/upsert. %>
      <%= render "admin/mediciones/form", miembro: @miembro, medicion: @medicion,
            url: admin_user_mediciones_path(@miembro), metodo: :post %>
    </div>
  </div>
</div>
