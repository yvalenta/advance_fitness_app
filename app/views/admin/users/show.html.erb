<% content_for :title, "#{@user.nombre.presence || @user.email_address} — Advance Fitness" %>

<div class="gradient-hero relative overflow-hidden">
  <div class="trama-puntos absolute inset-0"></div>
  <div class="relative mx-auto flex w-full max-w-4xl items-center gap-4 px-4 pb-14 pt-10">
    <%= render "shared/avatar", user: @user, clase: "size-14 text-lg" %>
    <div>
      <p class="eyebrow mb-1 text-volt">Miembro</p>
      <h1 class="font-display text-2xl font-bold text-white sm:text-3xl"><%= nombre_visible(@user) %></h1>
      <p class="mt-1.5 flex flex-wrap items-center gap-2 text-sm text-white/60">
        <span class="badge badge-sm badge-ghost"><%= @user.rol %></span>
        miembro desde <%= l @user.fecha_ingreso, format: :long %>
      </p>
    </div>
  </div>
</div>

<div class="mx-auto -mt-8 w-full max-w-4xl px-4 pb-12">
  <%# ── Editar perfil (Fase 6.13): staff edita datos básicos; rol, solo admin ── %>
  <div class="card animate-fade-up mb-6 border border-base-300 bg-base-100 shadow-md">
    <div class="card-body">
      <h2 class="card-title text-base">
        <span class="flex size-7 items-center justify-center rounded-lg bg-steel/15 text-steel-5">
          <%= render "shared/icono", nombre: :usuarios, clase: "size-4" %>
        </span>
        Editar perfil
      </h2>
      <% if @user.errors.any? %>
        <div role="alert" class="alert alert-error text-sm">
          <%= render "shared/icono", nombre: :alerta, clase: "size-5 shrink-0" %>
          <span><%= @user.errors.full_messages.to_sentence %></span>
        </div>
      <% end %>
      <%= form_with model: @user, url: admin_user_path(@user), method: :patch, class: "grid gap-3 sm:grid-cols-2" do |form| %>
        <label class="form-control">
          <span class="label-text mb-1 text-xs font-semibold">Nombre</span>
          <%= form.text_field :nombre, class: "input input-bordered w-full" %>
        </label>
        <label class="form-control">
          <span class="label-text mb-1 text-xs font-semibold">Correo</span>
          <%= form.email_field :email_address, class: "input input-bordered w-full" %>
        </label>
        <label class="form-control">
          <span class="label-text mb-1 text-xs font-semibold">Fecha de nacimiento</span>
          <%= form.date_field :fecha_nacimiento, class: "input input-bordered w-full" %>
        </label>
        <label class="form-control">
          <span class="label-text mb-1 text-xs font-semibold">Sexo</span>
          <%= form.select :sexo, [ [ "Masculino", "M" ], [ "Femenino", "F" ] ], { include_blank: "Sin definir" }, class: "select select-bordered w-full" %>
        </label>
        <label class="form-control">
          <span class="label-text mb-1 text-xs font-semibold">Nivel de actividad</span>
          <%= form.select :nivel_actividad, User::NIVELES_ACTIVIDAD.map { |valor, etiqueta| [ etiqueta, valor ] },
                { include_blank: "Sin definir" }, class: "select select-bordered w-full" %>
        </label>
        <label class="form-control">
          <span class="label-text mb-1 text-xs font-semibold">Somatotipo</span>
          <%= form.select :somatotipo, User::SOMATOTIPOS.map { |s| [ s.capitalize, s ] },
                { include_blank: "Sin definir" }, class: "select select-bordered w-full" %>
        </label>
        <% if Current.user.admin? %>
          <label class="form-control">
            <span class="label-text mb-1 text-xs font-semibold">Rol</span>
            <select name="user[rol]" class="select select-bordered w-full">
              <% User::ROLES.each do |rol| %>
                <option value="<%= rol %>" <%= "selected" if @user.rol == rol %>><%= rol %></option>
              <% end %>
            </select>
          </label>
        <% end %>
        <div class="sm:col-span-2">
          <%= form.submit "Guardar cambios", class: "btn btn-primary font-bold" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="grid items-start gap-6 md:grid-cols-2">
    <div class="card animate-fade-up border border-base-300 bg-base-100 shadow-md">
      <div class="card-body">
        <h2 class="card-title text-base">
          <span class="flex size-7 items-center justify-center rounded-lg bg-volt/15 text-volt-d">
            <%= render "shared/icono", nombre: :escudo, clase: "size-4" %>
          </span>
          Membresía
        </h2>
        <% if @user.membresia %>
          <p><%= badge_estado(@user.membresia.estado) %></p>
          <p class="text-sm text-steel-5">Vence el <%= l @user.membresia.fecha_vencimiento, format: :long %> (<%= @user.membresia.dias_restantes %> días)</p>
          <div class="card-actions mt-1">
            <%= link_to "Gestionar", edit_admin_membresia_path(@user.membresia), class: "btn btn-primary btn-sm font-bold" %>
          </div>
        <% else %>
          <p class="text-sm text-steel-3">Sin membresía.</p>
          <div class="card-actions mt-1">
            <%= link_to "Crear membresía", new_admin_membresia_path, class: "btn btn-primary btn-sm font-bold" %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="card animate-fade-up fade-delay-1 border border-base-300 bg-base-100 shadow-md">
      <div class="card-body">
        <h2 class="card-title text-base">
          <span class="flex size-7 items-center justify-center rounded-lg bg-base-200 text-steel-5">
            <%= render "shared/icono", nombre: :reloj, clase: "size-4" %>
          </span>
          Últimos accesos
        </h2>
        <% if @accesos.any? %>
          <ul class="flex flex-col gap-2 text-sm">
            <% @accesos.each do |acceso| %>
              <li class="flex items-center gap-2">
                <%= badge_estado(acceso.tipo) %>
                <span class="text-steel-5"><%= l acceso.fecha_hora, format: :short %></span>
                <% unless acceso.dentro_de_horario? %>
                  <span class="badge badge-sm badge-error">fuera de horario</span>
                <% end %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-sm text-steel-3">Sin accesos registrados.</p>
        <% end %>
      </div>
    </div>

    <div class="card animate-fade-up fade-delay-2 border border-base-300 bg-base-100 shadow-md">
      <div class="card-body">
        <h2 class="card-title text-base">
          <span class="flex size-7 items-center justify-center rounded-lg bg-pulse/15 text-pulse">
            <%= render "shared/icono", nombre: :fuego, clase: "size-4" %>
          </span>
          Plan
        </h2>
        <% if @plan %>
          <p class="flex flex-wrap items-center gap-1.5">
            <span class="badge badge-sm <%= @plan.aprobado? ? "badge-success" : "badge-warning" %>">
              <%= @plan.aprobado? ? "publicado" : @plan.estado %>
            </span>
            <span class="text-xs text-steel-3">origen: <%= origen_plan(@plan) %></span>
          </p>
          <div class="card-actions mt-1">
            <%= link_to "Ver / editar plan →", plan_personalizado_path(@plan), class: "btn btn-primary btn-sm font-bold" %>
          </div>
        <% else %>
          <p class="text-sm text-steel-3">Sin plan aún.</p>
        <% end %>
      </div>
    </div>

    <div class="card animate-fade-up fade-delay-2 border border-base-300 bg-base-100 shadow-md md:col-span-2">
      <div class="card-body">
        <h2 class="card-title text-base">
          <span class="flex size-7 items-center justify-center rounded-lg bg-ocean/15 text-ocean">
            <%= render "shared/icono", nombre: :actividad, clase: "size-4" %>
          </span>
          Antropometría
        </h2>
        <% if (ultima = @user.ultima_medicion) %>
          <p class="text-sm text-steel-5">
            Última medición el <%= l ultima.fecha, format: :long %> ·
            <strong><%= ultima.peso_kg %> kg</strong><% if ultima.imc %> · IMC <%= ultima.imc %><% end %>
          </p>
        <% else %>
          <p class="text-sm text-steel-3">Sin mediciones registradas.</p>
        <% end %>
        <div class="card-actions mt-1">
          <%= link_to "Ver historial", admin_user_mediciones_path(@user), class: "btn btn-ghost btn-sm" %>
          <% if (ultima = @user.ultima_medicion) %>
            <%= link_to "Editar últimas medidas", edit_admin_user_medicion_path(@user, ultima), class: "btn btn-ghost btn-sm" %>
          <% end %>
          <%= link_to "Nueva medición", new_admin_user_medicion_path(@user), class: "btn btn-primary btn-sm font-bold" %>
        </div>
      </div>
    </div>
  </div>

  <%# ── Progreso (Fase 6.13): las mismas gráficas que ve el propio miembro ── %>
  <div class="mt-6">
    <h2 class="mb-3 font-display text-lg font-bold">Progreso</h2>
    <% peso_actual = @progreso.pesos.last&.last %>
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4">
      <%= render "shared/metric_card", titulo: "Peso actual", valor: peso_actual ? "#{peso_actual} kg" : "—",
            icono: :actividad, acento: "bg-ocean/15 text-ocean" %>
      <%= render "shared/metric_card", titulo: "Visitas este mes", valor: @progreso.visitas_mes,
            descripcion: "Check-ins en recepción", icono: :rayo, acento: "bg-volt/15 text-volt-d" %>
      <%= render "shared/metric_card", titulo: "Adherencia del mes",
            valor: @progreso.dias_registrados.positive? ? "#{((@progreso.dias_en_meta * 100.0) / @progreso.dias_registrados).round}%" : "—",
            descripcion: @progreso.dias_registrados.positive? ? "#{@progreso.dias_en_meta} de #{@progreso.dias_registrados} días en meta" : nil,
            icono: :fuego, acento: "bg-pulse/15 text-pulse" %>
    </div>
    <div class="mt-4 grid items-start gap-6 lg:grid-cols-2">
      <%= render "shared/grafica_peso", progreso: @progreso %>
      <%= render "shared/grafica_calorias", progreso: @progreso %>
      <div class="lg:col-span-2"><%= render "shared/grafica_asistencia", progreso: @progreso %></div>
    </div>
  </div>
</div>
