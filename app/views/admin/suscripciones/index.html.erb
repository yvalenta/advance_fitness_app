<% content_for :title, "Suscripciones — Advance Fitness" %>

<%= render "shared/encabezado",
      titulo: "Suscripciones",
      descripcion: "Altas del plan Personalizado: al crearlas se encola el análisis del plan.",
      accion: link_to(new_admin_suscripcion_path, class: "btn btn-primary font-bold") { "Nueva suscripción" } %>

<div class="mx-auto -mt-8 w-full max-w-6xl px-4 pb-12">
  <div class="card animate-fade-up border border-base-300 bg-base-100 shadow-md">
    <div class="card-body">
      <%= turbo_frame_tag "resultados_suscripciones", data: { controller: "buscador-en-vivo" } do %>
        <%= form_with url: admin_suscripciones_path, method: :get, class: "mb-1",
              data: { turbo_frame: "resultados_suscripciones", buscador_en_vivo_target: "form" } do %>
          <label class="input input-bordered flex max-w-sm items-center gap-2">
            <%= render "shared/icono", nombre: :busqueda, clase: "size-4 text-steel-3" %>
            <input type="search" name="q" value="<%= @q %>" placeholder="Buscar por nombre o correo…"
                   class="grow" data-action="input->buscador-en-vivo#buscar">
          </label>
        <% end %>

        <% if @q.present? %>
          <p class="text-xs text-steel-3">
            <%= pluralize(@suscripciones.size, "resultado") %> para "<%= @q %>" ·
            <%= link_to "Limpiar", admin_suscripciones_path, data: { turbo_frame: "resultados_suscripciones" }, class: "link" %>
          </p>
        <% end %>

        <% if @suscripciones.any? %>
          <div class="overflow-x-auto">
            <table class="table">
              <thead>
                <tr class="text-xs uppercase tracking-wider text-steel-3">
                  <th>Miembro</th><th>Plan</th><th>Estado</th><th>Inicio</th><th>Fin</th><th></th>
                </tr>
              </thead>
              <tbody>
                <% @suscripciones.each do |suscripcion| %>
                  <tr class="hover:bg-base-200">
                    <td>
                      <%= link_to admin_user_path(suscripcion.user), class: "flex items-center gap-3 hover:underline" do %>
                        <%= render "shared/avatar", user: suscripcion.user %>
                        <div>
                          <p class="font-semibold"><%= nombre_visible(suscripcion.user) %></p>
                          <p class="text-xs text-steel-3"><%= suscripcion.user.email_address %></p>
                        </div>
                      <% end %>
                    </td>
                    <td>
                      <span class="badge badge-sm <%= suscripcion.plan.personalizado? ? "badge-primary" : "badge-ghost" %>"><%= suscripcion.plan.nombre %></span>
                      <% if suscripcion.incluida_en_membresia? %>
                        <%= link_to edit_admin_membresia_path(suscripcion.membresia),
                              class: "badge badge-sm badge-outline ml-1", title: "Incluida con la membresía pagada el #{l suscripcion.membresia.fecha_inicio}" do %>
                          Incluida con membresía
                        <% end %>
                      <% end %>
                    </td>
                    <td>
                      <span class="badge badge-sm <%= { "activa" => "badge-success", "programada" => "badge-info", "cancelada" => "badge-ghost", "expirada" => "badge-error" }[suscripcion.estado] %>">
                        <%= suscripcion.estado %>
                      </span>
                    </td>
                    <td class="text-sm text-steel-5"><%= l suscripcion.fecha_inicio %></td>
                    <td class="text-sm text-steel-5"><%= suscripcion.fecha_fin ? l(suscripcion.fecha_fin) : "—" %></td>
                    <td class="text-right">
                      <div class="flex items-center justify-end gap-1">
                        <% if (plan = suscripcion.user.plan_actual) %>
                          <%= link_to plan_personalizado_path(plan), class: "btn btn-ghost btn-xs" do %>
                            <%= plan.aprobado? ? "Editar plan" : "Revisar plan" %>
                            <span class="badge badge-xs <%= plan.aprobado? ? "badge-success" : "badge-warning" %>"></span>
                          <% end %>
                        <% end %>
                        <% if suscripcion.activa? %>
                          <%= button_to "Cancelar", admin_suscripcion_path(suscripcion), method: :patch,
                                class: "btn btn-ghost btn-xs text-error",
                                data: { turbo_confirm: "¿Cancelar la suscripción de #{nombre_visible(suscripcion.user)}?" } %>
                        <% end %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="flex flex-col items-center gap-3 rounded-xl bg-base-200 py-12 text-center">
            <%= render "shared/icono", nombre: :rayo, clase: "size-8 text-steel-1" %>
            <p class="text-sm text-steel-3"><%= @q.present? ? "Nada coincide con tu búsqueda." : "Aún no hay suscripciones al plan Personalizado." %></p>
            <% unless @q.present? %>
              <%= link_to "Crear la primera", new_admin_suscripcion_path, class: "btn btn-primary btn-sm font-bold" %>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
