<% content_for :title, "Nueva membresía — #{Negocio.nombre}" %>

<%= render "shared/encabezado",
      titulo: "Nueva membresía",
      descripcion: "Alta del plan mensual con su primer pago en una sola operación." %>

<div class="mx-auto -mt-8 w-full max-w-2xl px-4 pb-12">
  <div class="card animate-fade-up border border-base-300 bg-base-100 shadow-md">
    <div class="card-body">
      <% if @membresia.errors.any? %>
        <div role="alert" class="alert alert-error text-sm">
          <%= render "shared/icono", nombre: :alerta, clase: "size-5 shrink-0" %>
          <span><%= @membresia.errors.full_messages.to_sentence %></span>
        </div>
      <% end %>

      <%= form_with model: @membresia, url: admin_membresias_path, class: "flex flex-col gap-6" do |form| %>
        <fieldset class="flex flex-col gap-4">
          <legend class="mb-3 flex items-center gap-2 text-sm font-bold">
            <span class="flex size-7 items-center justify-center rounded-lg bg-volt/15 text-volt-d">
              <%= render "shared/icono", nombre: :usuarios, clase: "size-4" %>
            </span>
            Miembro
          </legend>
          <label class="form-control">
            <span class="label-text mb-1 text-xs font-semibold">¿Para quién es la membresía?</span>
            <%= form.collection_select :user_id, User.where.missing(:membresia).order(:nombre), :id, :nombre,
                  { prompt: "Selecciona un miembro" }, { class: "select select-bordered w-full", required: true } %>
          </label>
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="form-control">
              <span class="label-text mb-1 text-xs font-semibold">Fecha de inicio</span>
              <%= form.date_field :fecha_inicio, class: "input input-bordered w-full", required: true %>
            </label>
            <div class="flex items-end pb-3 text-xs text-steel-3">
              Vence automáticamente 1 mes después.
            </div>
          </div>
        </fieldset>

        <div class="divider my-0"></div>

        <fieldset class="flex flex-col gap-4">
          <legend class="mb-3 flex items-center gap-2 text-sm font-bold">
            <span class="flex size-7 items-center justify-center rounded-lg bg-volt/15 text-volt-d">
              <%= render "shared/icono", nombre: :tarjeta, clase: "size-4" %>
            </span>
            Primer pago
          </legend>
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="form-control">
              <span class="label-text mb-1 text-xs font-semibold">Monto (COP)</span>
              <%= number_field_tag "membresia[monto]", Negocio.precio_mensualidad, min: 1000, step: 1000, required: true,
                    placeholder: number_with_delimiter(Negocio.precio_mensualidad, delimiter: "."), class: "input input-bordered w-full" %>
            </label>
            <label class="form-control">
              <span class="label-text mb-1 text-xs font-semibold">Método de pago</span>
              <%= select_tag "membresia[metodo]", options_for_select(Pago::METODOS), class: "select select-bordered w-full" %>
            </label>
          </div>
        </fieldset>

        <div class="flex gap-2 pt-2">
          <%= form.submit "Crear membresía", class: "btn btn-primary font-bold" %>
          <%= link_to "Cancelar", admin_membresias_path, class: "btn btn-ghost" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
