<% content_for :title, "Gestionar membresía — Advance Fitness" %>

<div class="gradient-hero relative overflow-hidden">
  <div class="trama-puntos absolute inset-0"></div>
  <div class="relative mx-auto flex w-full max-w-2xl items-center gap-4 px-4 pb-14 pt-10">
    <%= render "shared/avatar", user: @membresia.user, clase: "size-14 text-lg" %>
    <div>
      <p class="eyebrow mb-1 text-volt">Membresía</p>
      <h1 class="font-display text-2xl font-bold text-white sm:text-3xl"><%= nombre_visible(@membresia.user) %></h1>
      <p class="mt-1.5 flex flex-wrap items-center gap-2 text-sm text-white/60">
        <%= badge_estado(@membresia.estado) %>
        vence el <%= l @membresia.fecha_vencimiento, format: :long %> (<%= @membresia.dias_restantes %> días)
      </p>
    </div>
  </div>
</div>

<div class="mx-auto -mt-8 flex w-full max-w-2xl flex-col gap-6 px-4 pb-12">
  <div class="card animate-fade-up border-2 border-volt/50 bg-base-100 shadow-md">
    <div class="card-body">
      <h2 class="card-title text-base">
        <span class="flex size-7 items-center justify-center rounded-lg bg-volt/15 text-volt-d">
          <%= render "shared/icono", nombre: :rayo, clase: "size-4" %>
        </span>
        Renovar (registra el pago)
      </h2>
      <%= form_with url: admin_membresia_renovacion_path(@membresia), method: :post, class: "flex flex-wrap items-end gap-3" do %>
        <label class="form-control flex-1 basis-40">
          <span class="label-text mb-1 text-xs font-semibold">Monto (COP)</span>
          <%= number_field_tag :monto, nil, min: 1, step: 1000, required: true, placeholder: "80.000", class: "input input-bordered w-full" %>
        </label>
        <label class="form-control flex-1 basis-36">
          <span class="label-text mb-1 text-xs font-semibold">Método</span>
          <%= select_tag :metodo, options_for_select(Pago::METODOS), class: "select select-bordered w-full" %>
        </label>
        <%= submit_tag "Renovar 1 mes", class: "btn btn-primary font-bold" %>
      <% end %>
    </div>
  </div>

  <div class="card animate-fade-up fade-delay-1 border border-base-300 bg-base-100 shadow-md">
    <div class="card-body">
      <h2 class="card-title text-base">
        <span class="flex size-7 items-center justify-center rounded-lg bg-base-200 text-steel-5">
          <%= render "shared/icono", nombre: :calendario, clase: "size-4" %>
        </span>
        Editar
      </h2>
      <% if @membresia.errors.any? %>
        <div role="alert" class="alert alert-error text-sm">
          <%= render "shared/icono", nombre: :alerta, clase: "size-5 shrink-0" %>
          <span><%= @membresia.errors.full_messages.to_sentence %></span>
        </div>
      <% end %>

      <%= form_with model: @membresia, url: admin_membresia_path(@membresia), method: :patch, class: "flex flex-col gap-4" do |form| %>
        <div class="grid gap-4 sm:grid-cols-2">
          <label class="form-control">
            <span class="label-text mb-1 text-xs font-semibold">Estado</span>
            <%= form.select :estado, options_for_select(Membresia::ESTADOS, @membresia.estado), {}, { class: "select select-bordered w-full" } %>
          </label>
          <label class="form-control">
            <span class="label-text mb-1 text-xs font-semibold">Fecha de inicio</span>
            <%= form.date_field :fecha_inicio, class: "input input-bordered w-full" %>
          </label>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <label class="form-control">
            <span class="label-text mb-1 text-xs font-semibold">Horario — apertura</span>
            <%= time_field_tag "membresia[hora_apertura]", @membresia.hora_apertura, class: "input input-bordered w-full" %>
          </label>
          <label class="form-control">
            <span class="label-text mb-1 text-xs font-semibold">Horario — cierre</span>
            <%= time_field_tag "membresia[hora_cierre]", @membresia.hora_cierre, class: "input input-bordered w-full" %>
          </label>
        </div>

        <div class="flex gap-2">
          <%= form.submit "Guardar cambios", class: "btn btn-primary font-bold" %>
          <%= link_to "Volver", admin_membresias_path, class: "btn btn-ghost" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="card animate-fade-up fade-delay-2 border border-base-300 bg-base-100 shadow-md">
    <div class="card-body">
      <h2 class="card-title text-base">
        <span class="flex size-7 items-center justify-center rounded-lg bg-base-200 text-steel-5">
          <%= render "shared/icono", nombre: :tarjeta, clase: "size-4" %>
        </span>
        Pagos
      </h2>
      <div class="overflow-x-auto">
        <table class="table table-sm">
          <thead>
            <tr class="text-xs uppercase tracking-wider text-steel-3">
              <th>Fecha</th><th>Período</th><th>Monto</th><th>Método</th><th>Registró</th>
            </tr>
          </thead>
          <tbody>
            <% @membresia.pagos.order(fecha_pago: :desc).each do |pago| %>
              <tr class="hover:bg-base-200">
                <td class="text-sm"><%= l pago.fecha_pago %></td>
                <td class="text-xs text-steel-5"><%= l pago.periodo_inicio %> — <%= l pago.periodo_fin %></td>
                <td class="font-display font-bold"><%= cop pago.monto %></td>
                <td><span class="badge badge-sm badge-ghost"><%= pago.metodo %></span></td>
                <td class="text-xs text-steel-3"><%= pago.registrado_por.nombre %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
