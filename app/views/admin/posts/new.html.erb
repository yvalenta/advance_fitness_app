<% content_for :title, "Nuevo post — #{Negocio.nombre}" %>

<%= render "shared/encabezado", titulo: "Nuevo post", descripcion: "Se crea como borrador; publícalo cuando esté listo." %>

<div class="mx-auto -mt-8 w-full max-w-2xl px-4 pb-12">
  <div class="card animate-fade-up border border-base-300 bg-base-100 shadow-md">
    <div class="card-body">
      <%= render "form", post: @post, url: admin_posts_path %>
    </div>
  </div>
</div>
