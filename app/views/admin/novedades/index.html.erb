<% content_for :title, "Novedades — #{Negocio.nombre}" %>

<%= render "shared/encabezado",
      titulo: "Novedades",
      descripcion: "Anuncios cortos: clases, horarios especiales, retos.",
      accion: link_to(new_admin_novedad_path, class: "btn btn-primary font-bold") { "Nueva novedad" } %>

<div class="mx-auto -mt-8 w-full max-w-4xl px-4 pb-12">
  <div class="card animate-fade-up border border-base-300 bg-base-100 shadow-md">
    <div class="card-body">
      <% if @novedades.any? %>
        <div class="overflow-x-auto">
          <table class="table">
            <thead>
              <tr class="text-xs uppercase tracking-wider text-steel-3">
                <th>Título</th><th>Fecha del evento</th><th>Estado</th><th></th>
              </tr>
            </thead>
            <tbody>
              <% @novedades.each do |novedad| %>
                <tr class="hover:bg-base-200">
                  <td class="font-semibold"><%= novedad.titulo %></td>
                  <td class="text-sm text-steel-5"><%= novedad.fecha_evento ? l(novedad.fecha_evento) : "—" %></td>
                  <td>
                    <% if novedad.publicado? %>
                      <span class="badge badge-sm badge-success">publicada</span>
                    <% else %>
                      <span class="badge badge-sm badge-ghost">borrador</span>
                    <% end %>
                  </td>
                  <td class="text-right">
                    <div class="flex justify-end gap-1">
                      <%= link_to "Editar", edit_admin_novedad_path(novedad), class: "btn btn-ghost btn-xs" %>
                      <%= button_to "Eliminar", admin_novedad_path(novedad), method: :delete, class: "btn btn-ghost btn-xs text-error",
                            data: { turbo_confirm: "¿Eliminar la novedad \"#{novedad.titulo}\"?" } %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="flex flex-col items-center gap-3 rounded-xl bg-base-200 py-12 text-center">
          <%= render "shared/icono", nombre: :calendario, clase: "size-8 text-steel-1" %>
          <p class="text-sm text-steel-3">Aún no hay novedades.</p>
          <%= link_to "Crear la primera", new_admin_novedad_path, class: "btn btn-primary btn-sm font-bold" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
