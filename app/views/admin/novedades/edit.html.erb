<% content_for :title, "Editar novedad — #{Negocio.nombre}" %>

<%= render "shared/encabezado", titulo: "Editar novedad", descripcion: @novedad.titulo %>

<div class="mx-auto -mt-8 w-full max-w-2xl px-4 pb-12">
  <div class="card animate-fade-up border border-base-300 bg-base-100 shadow-md">
    <div class="card-body">
      <%= render "form", novedad: @novedad, url: admin_novedad_path(@novedad) %>
    </div>
  </div>
</div>
