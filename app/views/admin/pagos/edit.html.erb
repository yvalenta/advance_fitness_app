<% content_for :title, "Corregir pago — Advance Fitness" %>

<%= render "shared/encabezado",
      titulo: "Corregir pago",
      descripcion: "#{nombre_visible(@pago.membresia.user)} · #{l @pago.fecha_pago} · período #{l @pago.periodo_inicio} — #{l @pago.periodo_fin}" %>

<div class="mx-auto -mt-8 w-full max-w-md px-4 pb-12">
  <div class="card animate-fade-up border border-base-300 bg-base-100 shadow-md">
    <div class="card-body">
      <% if @pago.errors.any? %>
        <div role="alert" class="alert alert-error text-sm">
          <%= render "shared/icono", nombre: :alerta, clase: "size-5 shrink-0" %>
          <span><%= @pago.errors.full_messages.to_sentence %></span>
        </div>
      <% end %>

      <%= form_with model: @pago, url: admin_pago_path(@pago), class: "flex flex-col gap-4" do |form| %>
        <label class="form-control">
          <span class="label-text mb-1 text-xs font-semibold">Monto (COP, mayor a $<%= number_with_delimiter(Pago::MONTO_MINIMO, delimiter: ".") %>)</span>
          <%= form.number_field :monto, min: Pago::MONTO_MINIMO + 1, step: 500, required: true, class: "input input-bordered w-full" %>
        </label>
        <label class="form-control">
          <span class="label-text mb-1 text-xs font-semibold">Método</span>
          <%= form.select :metodo, Pago::METODOS, {}, class: "select select-bordered w-full" %>
        </label>

        <div class="flex gap-2">
          <%= form.submit "Guardar corrección", class: "btn btn-primary font-bold" %>
          <%= link_to "Cancelar", admin_pagos_path, class: "btn btn-ghost" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
