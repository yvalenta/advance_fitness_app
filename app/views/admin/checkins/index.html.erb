<% content_for :title, "Check-in — Advance Fitness" %>

<div class="mx-auto max-w-6xl px-4 py-8">
  <h1 class="mb-6 font-display text-2xl font-bold">Check-in</h1>

  <div class="grid gap-6 lg:grid-cols-2">
    <div class="card border border-base-300 bg-base-100 shadow-sm">
      <div class="card-body">
        <h2 class="card-title text-base">Buscar miembro</h2>
        <%= form_with url: admin_checkins_path, method: :get, class: "join w-full" do |form| %>
          <%= form.text_field :q, value: @busqueda, placeholder: "Nombre o correo…",
                autofocus: true, class: "input input-bordered join-item w-full" %>
          <%= form.submit "Buscar", class: "btn btn-primary join-item" %>
        <% end %>

        <% if @busqueda.present? && @miembros.empty? %>
          <p class="mt-3 text-sm text-steel-3">Sin resultados para "<%= @busqueda %>".</p>
        <% end %>

        <% @miembros.each do |miembro| %>
          <div class="mt-3 flex items-center justify-between rounded-lg border border-base-300 p-3">
            <div>
              <p class="font-medium"><%= miembro.nombre.presence || miembro.email_address %></p>
              <p class="text-xs text-steel-3">
                <% if miembro.membresia %>
                  <%= badge_estado(miembro.membresia.estado) %>
                  vence <%= l miembro.membresia.fecha_vencimiento %>
                <% else %>
                  <span class="badge badge-sm badge-ghost">sin membresía</span>
                <% end %>
              </p>
            </div>
            <%= button_to "Registrar acceso", admin_checkins_path, params: { user_id: miembro.id },
                  class: "btn btn-primary btn-sm" %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="card border border-base-300 bg-base-100 shadow-sm">
      <div class="card-body">
        <h2 class="card-title text-base">Últimos accesos</h2>
        <table class="table table-sm">
          <thead>
            <tr><th>Miembro</th><th>Tipo</th><th>Horario</th><th>Fecha</th></tr>
          </thead>
          <tbody>
            <% @accesos.each do |acceso| %>
              <tr>
                <td><%= acceso.user.nombre.presence || acceso.user.email_address %></td>
                <td><%= badge_estado(acceso.tipo) %></td>
                <td>
                  <% if acceso.dentro_de_horario? %>
                    <span class="badge badge-sm badge-success">en horario</span>
                  <% else %>
                    <span class="badge badge-sm badge-error">fuera de horario</span>
                  <% end %>
                </td>
                <td class="text-xs text-steel-3"><%= l acceso.fecha_hora, format: :short %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
