<%# locals: (registro:, ejercicio:) %>
<%# Analista de Performance (SDD §18.4, Fase 12): solo lectura para el %>
<%# miembro — el botón de analizar vive en el panel de staff (ficha admin). %>
<% feedback = registro.feedback_ia %>
<div class="mt-2 flex flex-col gap-2 border-t border-base-300 pt-2">
  <% if feedback.nil? %>
    <p class="text-xs text-steel-3">Aún no hay análisis para este período. Pídele a tu entrenador que lo genere.</p>
  <% elsif feedback.fallido? %>
    <p class="text-xs text-error">El análisis no pudo completarse. Pídele a tu entrenador que lo intente de nuevo.</p>
  <% elsif feedback.generando? %>
    <div class="flex items-center gap-2 text-sm text-steel-3">
      <span class="loading loading-spinner loading-xs"></span> Analizando tu entrenamiento…
    </div>
  <% elsif feedback.listo? %>
    <% color = { "progreso" => "badge-success", "estancado" => "badge-warning", "alerta" => "badge-error" }.fetch(feedback.diagnostico) %>
    <div class="flex flex-col gap-1">
      <span class="badge badge-sm <%= color %> w-fit capitalize"><%= feedback.diagnostico %></span>
      <p class="text-sm text-steel-7"><%= feedback.analisis %></p>
      <p class="text-sm font-semibold text-steel-7"><%= feedback.accion_recomendada %></p>
    </div>
  <% end %>
</div>
