<%# Plan del miembro (solo lectura): rutina + nutrición con macros por comida. %>
<%# usuario = Current.user en la vista; plan.user en el broadcast Turbo (donde %>
<%# Current.user es nil). Sin strict-locals: el broadcast inyecta el local del %>
<%# modelo (plan_personalizado). SDD Fase 5.8. %>
<% plan = local_assigns[:plan] || local_assigns[:plan_personalizado] %>
<% usuario = local_assigns[:usuario] || Current.user %>
<% nutricion = plan.plan_nutricional %>
<% comidas = Array(nutricion["comidas"]) %>
<% proteinas = comidas.sum { |c| c["proteinas_g"].to_i } %>
<% carbohidratos = comidas.sum { |c| c["carbohidratos_g"].to_i } %>
<% grasas = comidas.sum { |c| c["grasas_g"].to_i } %>
<% kcal_macros = (proteinas * 4) + (carbohidratos * 4) + (grasas * 9) %>
<% pct = ->(kcal) { kcal_macros.positive? ? ((kcal * 100.0) / kcal_macros).round : 0 } %>
<% objetivo_dia = nutricion["kcal_diarias"].to_i %>
<% objetivo_dia = comidas.sum { |c| c["kcal"].to_i } if objetivo_dia.zero? %>
<% propio = plan.user_id == usuario&.id %>

<div id="<%= dom_id(plan, :mi_plan) %>" class="flex flex-col gap-6">
  <%= render "planes_personalizados/rutina", rutina: plan.rutina, plan: plan, usuario: usuario %>

  <%# El plan sugerido por reglas es solo entrenamiento: sin comidas no hay card %>
  <% if comidas.any? %>
  <div class="card border border-base-300 bg-base-100 shadow-md"
       data-controller="plan-nutricional"
       data-plan-nutricional-objetivo-value="<%= objetivo_dia %>">
    <div class="card-body">
      <h2 class="card-title text-base">
        <span class="flex size-7 items-center justify-center rounded-lg bg-pulse/15 text-pulse">
          <%= render "shared/icono", nombre: :fuego, clase: "size-4" %>
        </span>
        Plan nutricional
        <span class="badge badge-ghost badge-sm ml-auto"><%= number_with_delimiter(objetivo_dia, delimiter: ".") %> kcal/día</span>
      </h2>

      <%# Distribución de macros del día — se despliega al cargar %>
      <div class="mt-1">
        <div class="flex h-3 w-full overflow-hidden rounded-full bg-base-200">
          <div class="bg-volt transition-[width] duration-700 ease-out" style="width: 0%"
               data-plan-nutricional-target="segmento" data-pct="<%= pct.call(proteinas * 4) %>"></div>
          <div class="bg-ocean transition-[width] duration-700 ease-out delay-150" style="width: 0%"
               data-plan-nutricional-target="segmento" data-pct="<%= pct.call(carbohidratos * 4) %>"></div>
          <div class="bg-warning transition-[width] duration-700 ease-out delay-300" style="width: 0%"
               data-plan-nutricional-target="segmento" data-pct="<%= pct.call(grasas * 9) %>"></div>
        </div>
        <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-xs text-steel-5">
          <span class="flex items-center gap-1.5"><span class="size-2.5 rounded-full bg-volt"></span>Proteína <%= proteinas %>g · <%= pct.call(proteinas * 4) %>%</span>
          <span class="flex items-center gap-1.5"><span class="size-2.5 rounded-full bg-ocean"></span>Carbohidratos <%= carbohidratos %>g · <%= pct.call(carbohidratos * 4) %>%</span>
          <span class="flex items-center gap-1.5"><span class="size-2.5 rounded-full bg-warning"></span>Grasas <%= grasas %>g · <%= pct.call(grasas * 9) %>%</span>
        </div>
      </div>

      <%# Progreso del día: marca comidas y mira el acumulado %>
      <div class="mt-3 rounded-xl bg-base-200 p-4">
        <div class="flex flex-wrap items-baseline justify-between gap-2">
          <p class="text-sm text-steel-5">
            Comido del plan:
            <span class="font-display text-2xl font-bold text-base-content" data-plan-nutricional-target="consumidas" data-actual="0">0</span>
            <span class="text-steel-3">/ <%= number_with_delimiter(objetivo_dia, delimiter: ".") %> kcal</span>
          </p>
          <span class="badge badge-success gap-1 font-semibold" hidden data-plan-nutricional-target="estado">
            <%= render "shared/icono", nombre: :check, clase: "size-3" %>
            ¡Plan del día completo!
          </span>
        </div>
        <div class="mt-2 h-2 w-full overflow-hidden rounded-full bg-base-300">
          <div class="h-full rounded-full bg-volt transition-[width] duration-500 ease-out" style="width: 0%"
               data-plan-nutricional-target="barra"></div>
        </div>
        <%# Alerta viva (Fase 5.11): editar kcal por encima o por debajo del objetivo %>
        <p hidden class="mt-2 rounded-lg px-3 py-2 text-xs font-semibold" data-plan-nutricional-target="alerta"></p>
      </div>

      <% if propio %>
        <p class="mt-3 text-xs text-steel-3">Marca lo que comiste y, si cambiaste algo, ajusta las kcal y anota qué comiste.</p>
      <% end %>

      <div class="mt-3 grid gap-3 sm:grid-cols-2">
        <% comidas.each do |comida| %>
          <% cp = comida["proteinas_g"].to_i * 4 %>
          <% cc = comida["carbohidratos_g"].to_i * 4 %>
          <% cg = comida["grasas_g"].to_i * 9 %>
          <% cm = cp + cc + cg %>
          <% cpct = ->(v) { cm.positive? ? ((v * 100.0) / cm).round : 0 } %>
          <div class="group card-hover relative flex flex-col rounded-xl border-2 border-base-300 p-4 transition-colors has-[:checked]:border-volt-d has-[:checked]:bg-volt/10"
               data-plan-nutricional-target="tarjeta">
            <label class="flex cursor-pointer items-start justify-between gap-2">
              <input type="checkbox" class="sr-only" data-kcal="<%= comida["kcal"].to_i %>" data-nombre="<%= comida["nombre"] %>"
                     data-plan-nutricional-target="comida" data-action="change->plan-nutricional#actualizar">
              <h3 class="font-semibold leading-tight"><%= comida["nombre"] %></h3>
              <div class="flex shrink-0 items-center gap-2">
                <span class="font-display text-sm font-bold text-volt-d"><%= comida["kcal"] %> kcal</span>
                <span class="flex size-5 items-center justify-center rounded-full border-2 border-base-300 text-steel opacity-40 transition-all group-has-[:checked]:border-volt-d group-has-[:checked]:bg-volt group-has-[:checked]:opacity-100">
                  <%= render "shared/icono", nombre: :check, clase: "size-3" %>
                </span>
              </div>
            </label>
            <p class="mt-1 text-sm text-steel-5 transition-opacity group-has-[:checked]:opacity-60"><%= comida["descripcion"] %></p>

            <%# Mini-barra de macros de la comida %>
            <div class="pt-3">
              <div class="flex h-1.5 w-full overflow-hidden rounded-full bg-base-200">
                <div class="bg-volt" style="width: <%= cpct.call(cp) %>%"></div>
                <div class="bg-ocean" style="width: <%= cpct.call(cc) %>%"></div>
                <div class="bg-warning" style="width: <%= cpct.call(cg) %>%"></div>
              </div>
              <div class="mt-1.5 flex gap-2 text-xs text-steel-5">
                <span class="inline-flex items-center gap-1"><span class="size-2 rounded-full bg-volt"></span>P <%= comida["proteinas_g"] %>g</span>
                <span class="inline-flex items-center gap-1"><span class="size-2 rounded-full bg-ocean"></span>C <%= comida["carbohidratos_g"] %>g</span>
                <span class="inline-flex items-center gap-1"><span class="size-2 rounded-full bg-warning"></span>G <%= comida["grasas_g"] %>g</span>
              </div>
            </div>

            <% if propio %>
              <%# El miembro ajusta lo que realmente comió (kcal + nota). No muta el plan del coach. %>
              <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-2 border-t border-base-200 pt-3">
                <label class="flex items-center gap-1.5 text-xs font-medium text-steel-5">
                  Comí
                  <input type="number" min="0" step="10" value="<%= comida["kcal"].to_i %>"
                         data-plan-nutricional-target="kcal" data-action="input->plan-nutricional#actualizar"
                         class="input input-bordered input-xs w-20 text-right font-mono">
                  kcal
                </label>
                <input type="text" placeholder="¿Qué comiste / cambiaste? (opcional)" maxlength="120"
                       data-plan-nutricional-target="nota" data-action="input->plan-nutricional#actualizar"
                       class="input input-bordered input-xs min-w-0 flex-1">
                <p hidden class="w-full text-xs font-semibold" data-plan-nutricional-target="hint"></p>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <% if propio %>
        <%= form_with url: registros_calorias_path, class: "mt-4 flex flex-col gap-1" do %>
          <input type="hidden" name="registro_caloria[kcal_consumidas]" value="0" data-plan-nutricional-target="kcalInput">
          <input type="hidden" name="registro_caloria[detalle]" value="{}" data-plan-nutricional-target="detalle">
          <button type="submit" class="btn btn-primary font-bold" disabled data-plan-nutricional-target="boton">
            Marca lo que comiste hoy
          </button>
          <p class="text-center text-xs text-steel-3">Reemplaza tu registro de calorías de hoy con lo que marcaste.</p>
        <% end %>
      <% end %>
    </div>
  </div>
  <% end %>
</div>
