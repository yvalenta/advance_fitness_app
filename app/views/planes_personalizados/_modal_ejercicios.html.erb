<%# Modal selector de plantillas de ejercicio, agrupadas por músculo (5.7b). %>
<%# locals: (plantillas:) %>
<dialog class="modal" data-modal-ejercicios-target="dialogo">
  <div class="modal-box max-w-lg">
    <div class="mb-3 flex items-center justify-between">
      <h3 class="font-display text-lg font-bold">Elegir un ejercicio</h3>
      <button type="button" class="btn btn-circle btn-ghost btn-sm" data-action="modal-ejercicios#cerrar" aria-label="Cerrar">✕</button>
    </div>

    <% if plantillas.any? %>
      <div class="flex max-h-[60vh] flex-col gap-4 overflow-y-auto pr-1">
        <% PlantillaEjercicio::MUSCULOS.each do |musculo| %>
          <% del_musculo = plantillas.select { |p| p.musculo == musculo } %>
          <% next if del_musculo.empty? %>
          <div>
            <p class="eyebrow mb-1.5 text-steel-3"><%= PlantillaEjercicio::NOMBRES_MUSCULO[musculo] %></p>
            <div class="flex flex-col gap-1" data-modal-ejercicios-target="grupo" data-musculo="<%= musculo %>">
              <% del_musculo.each do |p| %>
                <button type="button" class="btn btn-ghost btn-sm w-full justify-between font-normal"
                        data-action="modal-ejercicios#aplicar"
                        data-nombre="<%= p.nombre %>" data-series="<%= p.series %>"
                        data-repeticiones="<%= p.repeticiones %>" data-descanso="<%= p.descanso_seg %>">
                  <span><%= p.nombre %></span>
                  <span class="text-xs text-steel-3"><%= p.series %>×<%= p.repeticiones %></span>
                </button>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="py-6 text-center text-sm text-steel-3">Aún no hay plantillas de ejercicio.</p>
    <% end %>
  </div>
  <form method="dialog" class="modal-backdrop"><button aria-label="Cerrar">cerrar</button></form>
</dialog>
