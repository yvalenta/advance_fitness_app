<%# Editor del plan nutricional por comida con autosave (SDD Fase 5.6). %>
<%# locals: (plan:, plantillas:) %>
<% comidas = plan.comidas %>
<% total = plan.plan_nutricional["kcal_diarias"].to_i %>
<% total = comidas.sum { |c| c["kcal"].to_i } if total.zero? %>

<div id="editor_nutricional" class="card border border-base-300 bg-base-100 shadow-md"
     data-controller="autosave modal-plantillas"
     data-autosave-crear-url="<%= plan_personalizado_comidas_path(plan) %>"
     data-modal-plantillas-crear-url="<%= entrenador_plantillas_comida_path %>">
  <div class="card-body">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <h2 class="card-title text-base">
        <span class="flex size-7 items-center justify-center rounded-lg bg-pulse/15 text-pulse">
          <%= render "shared/icono", nombre: :fuego, clase: "size-4" %>
        </span>
        Plan nutricional
      </h2>
      <div class="flex items-center gap-3">
        <span class="font-display text-lg font-bold"><span data-autosave-target="total"><%= number_with_delimiter(total, delimiter: ".") %></span> <span class="text-xs font-normal text-steel-5">kcal/día</span></span>
        <span class="badge badge-ghost badge-sm" data-autosave-target="macros"></span>
      </div>
    </div>

    <div class="mt-1 flex h-2 w-full overflow-hidden rounded-full bg-base-200" aria-hidden="true">
      <div class="bg-volt transition-all duration-300" data-autosave-target="barra"></div>
      <div class="bg-ocean transition-all duration-300" data-autosave-target="barra"></div>
      <div class="bg-warning transition-all duration-300" data-autosave-target="barra"></div>
    </div>

    <%= render "planes_personalizados/comidas_editables", plan: plan, plantillas: plantillas %>

    <div class="mt-4 flex flex-wrap items-center gap-3 border-t border-base-200 pt-4">
      <% if plan.aprobado? %>
        <span class="badge badge-success gap-1 font-semibold">
          <%= render "shared/icono", nombre: :check, clase: "size-3" %> Publicado
        </span>
        <p class="text-xs text-steel-5">Los cambios se guardan y el miembro los ve al instante.</p>
      <% else %>
        <%= button_to "Publicar plan", publicar_plan_personalizado_path(plan),
              class: "btn btn-primary font-bold",
              data: { autosave_target: "publicar", turbo_confirm: "¿Publicar el plan? Quedará visible para el miembro." } %>
      <% end %>
      <span class="ml-auto text-xs text-steel-3" data-autosave-target="global">Todo guardado ✓</span>
    </div>

    <% if Current.user.staff? %>
      <details class="collapse-arrow collapse mt-3 border border-base-300">
        <summary class="collapse-title text-sm font-semibold">Modo avanzado: editar JSON</summary>
        <div class="collapse-content">
          <%= form_with url: plan_personalizado_path(plan), method: :patch, class: "flex flex-col gap-3" do %>
            <label class="form-control">
              <span class="label-text mb-1 text-xs font-semibold">Rutina</span>
              <%= text_area_tag :rutina, JSON.pretty_generate(plan.rutina),
                    rows: 12, class: "textarea textarea-bordered w-full font-mono text-xs" %>
            </label>
            <label class="form-control">
              <span class="label-text mb-1 text-xs font-semibold">Plan nutricional</span>
              <%= text_area_tag :plan_nutricional, JSON.pretty_generate(plan.plan_nutricional),
                    rows: 12, class: "textarea textarea-bordered w-full font-mono text-xs" %>
            </label>
            <%= submit_tag "Guardar JSON", class: "btn btn-sm btn-secondary self-start" %>
          <% end %>
        </div>
      </details>
    <% end %>
  </div>
</div>
