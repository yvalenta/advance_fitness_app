<%# Rutina semanal por día (tabs Stimulus) — solo lectura. Reutilizada por el %>
<%# plan del miembro y el broadcast en vivo. SDD Fase 5.8: filas-tarjeta con %>
<%# número, chips de series×reps y descanso. %>
<%# locals: (rutina:) %>
<% dias = Array(rutina["dias"]) %>

<div class="card border border-base-300 bg-base-100 shadow-md" data-controller="tabs">
  <div class="card-body">
    <h2 class="card-title text-base">
      <span class="flex size-7 items-center justify-center rounded-lg bg-volt/15 text-volt-d">
        <%= render "shared/icono", nombre: :actividad, clase: "size-4" %>
      </span>
      Rutina semanal
    </h2>

    <div role="tablist" class="tabs tabs-box w-fit max-w-full flex-nowrap overflow-x-auto">
      <% dias.each do |dia| %>
        <button type="button" role="tab" class="tab whitespace-nowrap font-semibold capitalize"
                data-tabs-target="tab" data-action="tabs#seleccionar"><%= dia["dia"] %></button>
      <% end %>
    </div>

    <% dias.each do |dia| %>
      <% ejercicios = Array(dia["ejercicios"]) %>
      <div data-tabs-target="panel" hidden class="flex flex-col gap-2.5">
        <% if dia["enfoque"].present? %>
          <div class="flex items-center gap-2 rounded-xl bg-volt/10 px-3 py-2">
            <%= render "shared/icono", nombre: :rayo, clase: "size-4 shrink-0 text-volt-d" %>
            <p class="text-sm font-semibold text-steel-7"><span class="text-steel-3">Enfoque:</span> <%= dia["enfoque"] %></p>
          </div>
        <% end %>

        <% if ejercicios.any? %>
          <% ejercicios.each_with_index do |ejercicio, indice| %>
            <div class="flex items-center gap-3 rounded-xl border border-base-300 bg-base-100 p-3 transition-colors hover:border-volt-d/40 hover:bg-base-200/50">
              <span class="flex size-8 shrink-0 items-center justify-center rounded-lg bg-base-200 font-display text-sm font-bold text-steel-5">
                <%= indice + 1 %>
              </span>
              <div class="min-w-0 flex-1">
                <p class="font-semibold leading-tight"><%= ejercicio["nombre"] %></p>
                <div class="mt-1.5 flex flex-wrap items-center gap-1.5">
                  <span class="inline-flex items-center gap-1 rounded-full bg-volt/15 px-2 py-0.5 text-xs font-bold text-volt-d">
                    <%= ejercicio["series"] %> × <%= ejercicio["repeticiones"] %>
                  </span>
                  <% if ejercicio["descanso_seg"].to_i.positive? %>
                    <span class="inline-flex items-center gap-1 rounded-full bg-base-200 px-2 py-0.5 text-xs font-medium text-steel-5">
                      <%= render "shared/icono", nombre: :reloj, clase: "size-3" %>
                      <%= ejercicio["descanso_seg"] %> s
                    </span>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <p class="rounded-xl bg-base-200 px-3 py-4 text-center text-sm text-steel-3">Día de descanso.</p>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
