<%# Rutina semanal unificada (Fase 6.8): una sola tarjeta con tabs por día que %>
<%# alterna, por ejercicio, entre modo lectura (checks de seguimiento, %>
<%# cápsulas, tap para ver ejecución) y modo edición (inputs inline) — sin %>
<%# duplicar el componente entre la vista del miembro y la del editor. %>
<%# locals: (rutina:, plan: nil, usuario: nil, plantillas: nil, siempre_editando: false) %>
<% plan = local_assigns[:plan] %>
<% usuario = local_assigns[:usuario] %>
<% siempre_editando = local_assigns.fetch(:siempre_editando, false) %>
<% dias = Array(rutina["dias"]) %>
<% con_seguimiento = plan && usuario && plan.user_id == usuario.id %>
<% editable = siempre_editando || (plan && usuario && PlanPersonalizadoPolicy.new(usuario, plan).editar_rutina?) %>
<% plantillas = local_assigns[:plantillas] || (PlantillaEjercicio.ordenadas if editable) %>
<% if con_seguimiento %>
  <% semana = Date.current.beginning_of_week %>
  <% registros = usuario.registros_entrenamiento.where(fecha: semana..(semana + 6)).index_by(&:fecha) %>
<% end %>

<div class="card border border-base-300 bg-base-100 shadow-md"
     data-controller="tabs modo-edicion seguimiento ayuda-ejercicio autosave modal-ejercicios"
     data-seguimiento-url-value="<%= registros_entrenamiento_path %>"
     data-autosave-clave="ejercicio"
     data-modal-ejercicios-crear-url="<%= entrenador_plantillas_ejercicio_path %>"
     data-modo-edicion-editando-value="<%= siempre_editando %>">
  <div class="card-body">
    <div class="flex flex-wrap items-center justify-between gap-2">
      <h2 class="card-title text-base">
        <span class="flex size-7 items-center justify-center rounded-lg bg-volt/15 text-volt-d">
          <%= render "shared/icono", nombre: :actividad, clase: "size-4" %>
        </span>
        Rutina semanal
      </h2>
      <div class="flex items-center gap-2">
        <% if con_seguimiento %>
          <span class="text-xs text-steel-3" data-modo-edicion-target="lectura" <%= "hidden" if siempre_editando %>>
            Marca lo que ejecutes · <span data-seguimiento-target="estado"></span>
          </span>
        <% end %>
        <% if editable %>
          <span class="text-xs text-steel-3" data-autosave-target="global" data-modo-edicion-target="edicion"
                <%= "hidden" unless siempre_editando %>>Todo guardado ✓</span>
        <% end %>
        <% if editable && !siempre_editando %>
          <button type="button" class="btn btn-ghost btn-xs gap-1 font-semibold"
                  data-action="modo-edicion#alternar" data-modo-edicion-target="boton">
            <%= render "shared/icono", nombre: :lapiz, clase: "size-3.5" %> Editar
          </button>
        <% end %>
      </div>
    </div>

    <% if editable && plan&.reglas? %>
      <div class="flex flex-wrap items-center gap-2">
        <span class="badge badge-success gap-1 font-semibold">
          <%= render "shared/icono", nombre: :check, clase: "size-3" %> Incluido con tu membresía
        </span>
        <span class="text-xs text-steel-5">Personaliza tu rutina: cambia los músculos del día y elige ejercicios de la biblioteca.</span>
      </div>
    <% end %>

    <div role="tablist" class="tabs tabs-box w-fit max-w-full flex-nowrap overflow-x-auto">
      <% dias.each do |dia| %>
        <button type="button" role="tab" class="tab whitespace-nowrap font-semibold capitalize"
                data-tabs-target="tab" data-action="tabs#seleccionar"><%= dia["dia"] %></button>
      <% end %>
    </div>

    <% dias.each_with_index do |dia, indice| %>
      <% if con_seguimiento %>
        <% fecha = semana + PlanPersonalizado::DIAS_OFFSET.fetch(dia["dia"].to_s.downcase, 0) %>
        <% registro = registros[fecha] %>
      <% end %>
      <div data-tabs-target="panel" hidden>
        <%= render "planes_personalizados/dia_editor", plan: plan, dia: dia, indice: indice,
              con_seguimiento: con_seguimiento, editable: editable, editando_por_defecto: siempre_editando,
              registro: registro, fecha: fecha %>
      </div>
    <% end %>
  </div>

  <% if editable %>
    <%= render "planes_personalizados/modal_ejercicios", plantillas: plantillas %>
  <% end %>
  <%= render "ejercicios/dialogo_ayuda" %>
</div>
