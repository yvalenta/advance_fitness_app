<% content_for :title, "Mi progreso — Advance Fitness" %>

<%= render "shared/encabezado",
      eyebrow: "Progreso",
      titulo: "Mi progreso",
      descripcion: "Peso, calorías y asistencia — con los datos que ya registras. Las mediciones con IMC llegan con el módulo de biometría." %>

<div class="mx-auto -mt-8 w-full max-w-5xl px-4 pb-12">
  <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4">
    <% peso_actual = @pesos.last&.last %>
    <% delta_peso = @pesos.size >= 2 ? (peso_actual - @pesos.first.last).round(1) : nil %>
    <div class="animate-fade-up">
      <%= render "shared/metric_card",
            titulo: "Peso actual",
            valor: peso_actual ? "#{peso_actual} kg" : "—",
            descripcion: delta_peso ? "#{delta_peso.positive? ? "+" : ""}#{delta_peso} kg desde tu primer objetivo" : "Se toma de tus objetivos fijados",
            icono: :actividad,
            acento: "bg-ocean/15 text-ocean" %>
    </div>
    <div class="animate-fade-up fade-delay-1">
      <%= render "shared/metric_card",
            titulo: "Visitas este mes",
            valor: @visitas_mes,
            descripcion: "Check-ins registrados en recepción",
            icono: :rayo,
            acento: "bg-volt/15 text-volt-d" %>
    </div>
    <div class="animate-fade-up fade-delay-2 col-span-2 sm:col-span-1">
      <%= render "shared/metric_card",
            titulo: "Adherencia del mes",
            valor: @dias_registrados.positive? ? "#{((@dias_en_meta * 100.0) / @dias_registrados).round}%" : "—",
            descripcion: @dias_registrados.positive? ? "#{@dias_en_meta} de #{@dias_registrados} días registrados en meta" : "Registra tus calorías para medirla",
            icono: :fuego,
            acento: "bg-pulse/15 text-pulse" %>
    </div>
  </div>

  <div class="mt-6 grid items-start gap-6 lg:grid-cols-2">
    <%# ── Tendencia de peso ─────────────────────────────────────── %>
    <div class="card animate-fade-up border border-base-300 bg-base-100 shadow-md">
      <div class="card-body">
        <h2 class="card-title text-base">
          <span class="flex size-7 items-center justify-center rounded-lg bg-ocean/15 text-ocean">
            <%= render "shared/icono", nombre: :actividad, clase: "size-4" %>
          </span>
          Tendencia de peso
          <span class="badge badge-ghost badge-sm ml-auto hidden sm:inline-flex">de tus objetivos</span>
        </h2>
        <% if @pesos.size >= 2 %>
          <% valores = @pesos.map(&:last) %>
          <% puntos = GraficaSvg.puntos(valores, ancho: 560, alto: 230) %>
          <% curva = GraficaSvg.camino_suave(puntos) %>
          <% base = 230 - GraficaSvg::MARGEN %>
          <div class="relative" data-controller="grafica"
               data-action="mousemove->grafica#mostrar mouseleave->grafica#ocultar">
            <svg viewBox="0 0 560 230" class="mt-1 w-full" role="img" aria-label="Tendencia de peso">
              <defs>
                <linearGradient id="grad-peso" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="var(--color-ocean)" stop-opacity="0.28"/>
                  <stop offset="100%" stop-color="var(--color-ocean)" stop-opacity="0"/>
                </linearGradient>
              </defs>
              <% [ 0.25, 0.5, 0.75 ].each do |fraccion| %>
                <line x1="<%= GraficaSvg::MARGEN %>" x2="<%= 560 - GraficaSvg::MARGEN %>"
                      y1="<%= (GraficaSvg::MARGEN + (fraccion * (230 - (2 * GraficaSvg::MARGEN)))).round(1) %>"
                      y2="<%= (GraficaSvg::MARGEN + (fraccion * (230 - (2 * GraficaSvg::MARGEN)))).round(1) %>"
                      stroke="var(--color-base-300)" stroke-width="1" stroke-dasharray="2 5"/>
              <% end %>
              <path class="grafica-area" d="<%= curva %> L <%= puntos.last[0] %>,<%= base %> L <%= puntos.first[0] %>,<%= base %> Z"
                    fill="url(#grad-peso)"/>
              <path class="grafica-linea" d="<%= curva %>" pathLength="1" fill="none" stroke="var(--color-ocean)"
                    stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
              <% puntos.each_with_index do |(x, y), indice| %>
                <circle class="grafica-punto" style="animation-delay: <%= 500 + (indice * 90) %>ms"
                        cx="<%= x %>" cy="<%= y %>" r="5" fill="var(--color-ocean)" stroke="white" stroke-width="2"
                        data-etiqueta="<%= valores[indice] %> kg · <%= l @pesos[indice].first %>"/>
              <% end %>
              <text x="<%= GraficaSvg::MARGEN %>" y="<%= GraficaSvg::MARGEN - 2 %>" class="fill-steel-3" font-size="10"><%= valores.max %> kg</text>
              <text x="<%= GraficaSvg::MARGEN %>" y="228" class="fill-steel-3" font-size="10"><%= l @pesos.first.first %></text>
              <text x="<%= 560 - GraficaSvg::MARGEN %>" y="228" text-anchor="end" class="fill-steel-3" font-size="10"><%= l @pesos.last.first %></text>
            </svg>
            <div class="pointer-events-none absolute z-10 -translate-x-1/2 whitespace-nowrap rounded-lg bg-steel px-2.5 py-1 text-xs font-semibold text-volt shadow-lg"
                 hidden data-grafica-target="tooltip"></div>
          </div>
          <p class="text-xs text-steel-3">Cada punto es el peso con el que fijaste un objetivo.</p>
        <% else %>
          <div class="flex flex-col items-center gap-2 rounded-xl bg-base-200 py-10 text-center">
            <%= render "shared/icono", nombre: :actividad, clase: "size-8 text-steel-1" %>
            <p class="max-w-sm text-sm text-steel-3">
              Necesitas al menos dos objetivos fijados para ver tu tendencia.
              <%= link_to "Actualiza tu objetivo", new_objetivo_path, class: "link font-semibold" %> cuando cambie tu peso.
            </p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Calorías de los últimos 14 días ───────────────────────── %>
    <div class="card animate-fade-up fade-delay-1 border border-base-300 bg-base-100 shadow-md">
      <div class="card-body">
        <h2 class="card-title text-base">
          <span class="flex size-7 items-center justify-center rounded-lg bg-volt/15 text-volt-d">
            <%= render "shared/icono", nombre: :fuego, clase: "size-4" %>
          </span>
          Calorías — 14 días
          <% if @objetivo %>
            <span class="badge badge-ghost badge-sm ml-auto hidden sm:inline-flex">objetivo <%= number_with_delimiter(@objetivo.objetivo_kcal, delimiter: ".") %></span>
          <% end %>
        </h2>
        <% if @objetivo && @calorias.any? { |_, kcal| kcal } %>
          <% tope = [ @calorias.filter_map(&:last).max, @objetivo.objetivo_kcal ].max * 1.15 %>
          <% base = 230 - GraficaSvg::MARGEN %>
          <% ranura = (560 - (2 * GraficaSvg::MARGEN)).fdiv(@calorias.size) %>
          <% y_objetivo = GraficaSvg.y_para(@objetivo.objetivo_kcal, alto: 230, min: 0, max: tope) %>
          <div class="relative" data-controller="grafica"
               data-action="mousemove->grafica#mostrar mouseleave->grafica#ocultar">
            <svg viewBox="0 0 560 230" class="mt-1 w-full" role="img" aria-label="Calorías diarias contra el objetivo">
              <% @calorias.each_with_index do |(fecha, kcal), indice| %>
                <% x = GraficaSvg::MARGEN + (indice * ranura) + (ranura * 0.15) %>
                <% if kcal %>
                  <% y = GraficaSvg.y_para(kcal, alto: 230, min: 0, max: tope) %>
                  <rect class="grafica-barra" style="animation-delay: <%= indice * 45 %>ms"
                        x="<%= x.round(1) %>" y="<%= y %>" width="<%= (ranura * 0.7).round(1) %>" height="<%= (base - y).round(1) %>"
                        rx="4" fill="var(--color-<%= kcal <= @objetivo.objetivo_kcal ? "volt" : "pulse" %>)"
                        fill-opacity="<%= kcal <= @objetivo.objetivo_kcal ? 0.95 : 0.8 %>"
                        data-etiqueta="<%= number_with_delimiter(kcal, delimiter: ".") %> kcal · <%= l fecha, format: "%d %b" %>"/>
                <% else %>
                  <rect x="<%= x.round(1) %>" y="<%= base - 3 %>" width="<%= (ranura * 0.7).round(1) %>" height="3"
                        rx="1.5" fill="var(--color-steel-1)"
                        data-etiqueta="Sin registro · <%= l fecha, format: "%d %b" %>"/>
                <% end %>
              <% end %>
              <line x1="<%= GraficaSvg::MARGEN %>" y1="<%= y_objetivo %>" x2="<%= 560 - GraficaSvg::MARGEN %>" y2="<%= y_objetivo %>"
                    stroke="var(--color-steel-5)" stroke-width="1.5" stroke-dasharray="6 4"/>
              <text x="<%= 560 - GraficaSvg::MARGEN %>" y="<%= y_objetivo - 5 %>" text-anchor="end" class="fill-steel-5" font-size="10">objetivo</text>
              <text x="<%= GraficaSvg::MARGEN %>" y="228" class="fill-steel-3" font-size="10"><%= l @calorias.first.first, format: "%d %b" %></text>
              <text x="<%= 560 - GraficaSvg::MARGEN %>" y="228" text-anchor="end" class="fill-steel-3" font-size="10"><%= l @calorias.last.first, format: "%d %b" %></text>
            </svg>
            <div class="pointer-events-none absolute z-10 -translate-x-1/2 whitespace-nowrap rounded-lg bg-steel px-2.5 py-1 text-xs font-semibold text-volt shadow-lg"
                 hidden data-grafica-target="tooltip"></div>
          </div>
          <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-steel-5">
            <span class="flex items-center gap-1.5"><span class="size-2.5 rounded-full bg-volt"></span>En meta</span>
            <span class="flex items-center gap-1.5"><span class="size-2.5 rounded-full bg-pulse"></span>Sobre el objetivo</span>
            <span class="flex items-center gap-1.5"><span class="size-2.5 rounded-full bg-steel-1"></span>Sin registro</span>
          </div>
        <% else %>
          <div class="flex flex-col items-center gap-2 rounded-xl bg-base-200 py-10 text-center">
            <%= render "shared/icono", nombre: :fuego, clase: "size-8 text-steel-1" %>
            <p class="max-w-sm text-sm text-steel-3">
              <% if @objetivo %>
                Aún no registras calorías.
                <%= link_to "Registra tu consumo de hoy", objetivo_path, class: "link font-semibold" %> para ver la gráfica.
              <% else %>
                <%= link_to "Fija tu objetivo calórico", new_objetivo_path, class: "link font-semibold" %> para comparar tus días contra la meta.
              <% end %>
            </p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Asistencia por semana ─────────────────────────────────── %>
    <div class="card animate-fade-up fade-delay-2 border border-base-300 bg-base-100 shadow-md lg:col-span-2">
      <div class="card-body">
        <h2 class="card-title text-base">
          <span class="flex size-7 items-center justify-center rounded-lg bg-base-200 text-steel-5">
            <%= render "shared/icono", nombre: :calendario, clase: "size-4" %>
          </span>
          Asistencia — últimas 8 semanas
        </h2>
        <% if @asistencia.sum(&:last).positive? %>
          <% tope = [ @asistencia.map(&:last).max, 1 ].max * 1.3 %>
          <% base = 150 - GraficaSvg::MARGEN %>
          <% ranura = (1000 - (2 * GraficaSvg::MARGEN)).fdiv(@asistencia.size) %>
          <div class="relative" data-controller="grafica"
               data-action="mousemove->grafica#mostrar mouseleave->grafica#ocultar">
            <svg viewBox="0 0 1000 150" class="mt-1 w-full" role="img" aria-label="Visitas al gimnasio por semana">
              <% @asistencia.each_with_index do |(semana, visitas), indice| %>
                <% x = GraficaSvg::MARGEN + (indice * ranura) + (ranura * 0.28) %>
                <% y = visitas.positive? ? GraficaSvg.y_para(visitas, alto: 150, min: 0, max: tope) : base - 3 %>
                <rect class="grafica-barra" style="animation-delay: <%= indice * 60 %>ms"
                      x="<%= x.round(1) %>" y="<%= y %>" width="<%= (ranura * 0.44).round(1) %>" height="<%= (base - y).round(1) %>"
                      rx="5" fill="var(--color-<%= visitas.positive? ? "volt" : "steel-1" %>)"
                      data-etiqueta="<%= visitas %> <%= "visita".pluralize(visitas) %> · semana del <%= l semana, format: "%d %b" %>"/>
                <% if visitas.positive? %>
                  <text x="<%= (x + (ranura * 0.22)).round(1) %>" y="<%= y - 7 %>" text-anchor="middle"
                        class="fill-steel-5" font-size="12" font-weight="bold"><%= visitas %></text>
                <% end %>
                <text x="<%= (x + (ranura * 0.22)).round(1) %>" y="148" text-anchor="middle" class="fill-steel-3" font-size="10">
                  <%= l semana, format: "%d %b" %>
                </text>
              <% end %>
            </svg>
            <div class="pointer-events-none absolute z-10 -translate-x-1/2 whitespace-nowrap rounded-lg bg-steel px-2.5 py-1 text-xs font-semibold text-volt shadow-lg"
                 hidden data-grafica-target="tooltip"></div>
          </div>
        <% else %>
          <div class="flex flex-col items-center gap-2 rounded-xl bg-base-200 py-10 text-center">
            <%= render "shared/icono", nombre: :calendario, clase: "size-8 text-steel-1" %>
            <p class="text-sm text-steel-3">Tus check-ins en recepción aparecerán aquí.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
