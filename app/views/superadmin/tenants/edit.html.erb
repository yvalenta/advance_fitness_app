<% content_for :title, "Editar #{@tenant.nombre} — Portal comercial" %>

<%= render "shared/encabezado",
      titulo: "Editar #{@tenant.nombre}",
      descripcion: "Ajusta marca, precios y módulos habilitados." %>

<div class="mx-auto -mt-8 w-full max-w-3xl px-4 pb-12">
  <div class="card animate-fade-up border border-base-300 bg-base-100 shadow-md">
    <div class="card-body">
      <%= render "form", tenant: @tenant, con_admin: false %>
    </div>
  </div>
</div>
