<% content_for :title, "Recuperar contraseña — Advance Fitness" %>

<div class="flex min-h-screen items-center justify-center px-4">
  <div class="card w-full max-w-sm border border-base-300 bg-base-100 shadow-sm">
    <div class="card-body">
      <h1 class="font-display text-lg font-bold">¿Olvidaste tu contraseña?</h1>
      <p class="text-sm opacity-60">Te enviaremos instrucciones a tu correo.</p>

      <% if (mensaje = flash[:alert]) %>
        <div role="alert" class="alert alert-error text-sm" id="alert"><span><%= mensaje %></span></div>
      <% end %>

      <%= form_with url: passwords_path, class: "flex flex-col gap-3" do |form| %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username",
              placeholder: "Correo electrónico", value: params[:email_address], class: "input input-bordered w-full" %>
        <%= form.submit "Enviar instrucciones", class: "btn btn-primary w-full" %>
      <% end %>

      <div class="mt-2 text-center text-sm">
        <%= link_to "Volver a iniciar sesión", new_session_path, class: "link link-hover opacity-70" %>
      </div>
    </div>
  </div>
</div>
