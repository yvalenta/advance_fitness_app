<% content_for :title, "Nueva contraseña — Advance Fitness" %>

<div class="flex min-h-screen items-center justify-center px-4">
  <div class="card w-full max-w-sm border border-base-300 bg-base-100 shadow-sm">
    <div class="card-body">
      <h1 class="font-display text-lg font-bold">Actualiza tu contraseña</h1>

      <% if (mensaje = flash[:alert]) %>
        <div role="alert" class="alert alert-error text-sm" id="alert"><span><%= mensaje %></span></div>
      <% end %>

      <%= form_with url: password_path(params[:token]), method: :put, class: "flex flex-col gap-3" do |form| %>
        <%= form.password_field :password, required: true, autocomplete: "new-password",
              placeholder: "Nueva contraseña", maxlength: 72, class: "input input-bordered w-full" %>
        <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password",
              placeholder: "Repite la nueva contraseña", maxlength: 72, class: "input input-bordered w-full" %>
        <%= form.submit "Guardar", class: "btn btn-primary w-full" %>
      <% end %>
    </div>
  </div>
</div>
