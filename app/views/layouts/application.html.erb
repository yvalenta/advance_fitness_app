<!DOCTYPE html>
<html lang="es" data-theme="advance">
  <head>
    <title><%= content_for(:title) || Negocio.nombre %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= Negocio.nombre %>">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#0b1220">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Tipografía de marca (SDD §06): Geist (body) + Space Grotesk (display) %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-base-200 font-sans text-base-content">
    <% if authenticated? %>
      <%= render "shared/navbar" %>
    <% end %>

    <% if flash[:alert].present? || flash[:notice].present? %>
      <%# pointer-events-none: el contenedor cubre toda la navbar (toast-top
          w-full) pero no debe bloquear sus clics — solo cada caja visible
          (pointer-events-auto) los captura. Se cierra solo a los 5s. %>
      <div class="toast toast-top toast-center z-50 w-full max-w-lg px-4 pt-16 pointer-events-none" data-controller="toast">
        <% if (mensaje = flash[:alert]) %>
          <div role="alert" class="alert alert-error pointer-events-auto shadow-lg" id="alert" data-toast-target="item">
            <%= render "shared/icono", nombre: :alerta, clase: "size-5 shrink-0" %>
            <span class="text-sm font-medium"><%= mensaje %></span>
            <button type="button" class="btn btn-ghost btn-xs btn-circle" data-action="toast#cerrar" aria-label="Cerrar">✕</button>
          </div>
        <% end %>
        <% if (mensaje = flash[:notice]) %>
          <div role="alert" class="alert alert-success pointer-events-auto shadow-lg" id="notice" data-toast-target="item">
            <%= render "shared/icono", nombre: :check, clase: "size-5 shrink-0" %>
            <span class="text-sm font-medium"><%= mensaje %></span>
            <button type="button" class="btn btn-ghost btn-xs btn-circle" data-action="toast#cerrar" aria-label="Cerrar">✕</button>
          </div>
        <% end %>
      </div>
    <% end %>

    <main>
      <%= yield %>
    </main>

    <footer class="flex flex-col items-center gap-0.5 py-4 text-center">
      <span class="font-mono text-[10px] text-base-content/40">v<%= Rails.application.config.x.version %></span>
      <span class="font-display text-[9px] font-medium uppercase tracking-[0.2em] text-base-content/25">Ynt-labs</span>
    </footer>

    <%# Confirmación global (Fase 6.9): reemplaza window.confirm/data-turbo-
        confirm, que no hacen nada en iOS con la app agregada a inicio. %>
    <dialog class="modal" data-controller="confirmacion" data-action="click->confirmacion#cerrarEnBackdrop">
      <div class="modal-box max-w-sm">
        <p class="text-sm font-medium" data-confirmacion-target="mensaje"></p>
        <div class="modal-action">
          <button type="button" class="btn btn-ghost btn-sm" data-action="confirmacion#cancelar">Cancelar</button>
          <button type="button" class="btn btn-error btn-sm" data-action="confirmacion#aceptar" data-confirmacion-target="aceptar">Confirmar</button>
        </div>
      </div>
      <div class="modal-backdrop"></div>
    </dialog>
  </body>
</html>
