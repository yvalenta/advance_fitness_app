<% content_for :title, "Borradores — Advance Fitness" %>

<%= render "shared/encabezado",
      eyebrow: "Panel del entrenador",
      titulo: "Planes por revisar",
      descripcion: "Analizados según la información de cada miembro; se publican solo cuando los apruebas." %>

<div class="mx-auto -mt-8 w-full max-w-4xl px-4 pb-12">
  <%# Turbo Streams: altas y cambios de estado (generando/fallido/borrador) llegan en vivo %>
  <%= turbo_stream_from "planes_pendientes" %>
  <div class="card animate-fade-up border border-base-300 bg-base-100 shadow-md">
    <div class="card-body">
      <div id="planes_pendientes" class="flex flex-col divide-y divide-base-200">
        <%= render partial: "entrenador/borradores/fila", collection: @pendientes, as: :plan %>
      </div>
      <% if @pendientes.empty? %>
        <div class="flex flex-col items-center gap-2 rounded-xl bg-base-200 py-12 text-center">
          <%= render "shared/icono", nombre: :check, clase: "size-8 text-steel-1" %>
          <p class="text-sm text-steel-3">No hay planes pendientes. ¡Todo al día!</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
