<% content_for :title, "#{@post.titulo} — #{Negocio.nombre}" %>

<%= render "shared/encabezado", titulo: @post.titulo, descripcion: "Por #{@post.autor.nombre} · #{l(@post.publicado_en&.to_date || @post.created_at.to_date, format: :long)}" %>

<div class="mx-auto -mt-8 w-full max-w-2xl px-4 pb-12">
  <div class="card animate-fade-up border border-base-300 bg-base-100 shadow-md">
    <div class="card-body">
      <% unless @post.publicado? %>
        <div role="alert" class="alert alert-warning text-sm">
          <%= render "shared/icono", nombre: :alerta, clase: "size-5 shrink-0" %>
          <span>Borrador: solo el staff puede ver este post.</span>
        </div>
      <% end %>
      <div class="trix-content prose max-w-none"><%= @post.contenido %></div>
    </div>
  </div>
  <div class="mt-4">
    <%= link_to "← Volver al blog", blog_path, class: "link text-sm" %>
  </div>
</div>
