<div class="navbar bg-secondary text-secondary-content shadow-md">
  <div class="mx-auto flex w-full max-w-6xl items-center px-4">
    <div class="flex-1 items-center">
      <%= link_to root_path, class: "flex items-center gap-2" do %>
        <%= render "shared/logo" %>
        <span class="font-display text-sm font-bold tracking-widest">ADVANCE FITNESS</span>
      <% end %>
    </div>
    <div class="flex items-center gap-3">
      <span class="hidden text-xs opacity-70 sm:block"><%= Current.user.nombre.presence || Current.user.email_address %></span>
      <%= button_to "Cerrar sesión", session_path, method: :delete, class: "btn btn-ghost btn-sm" %>
    </div>
  </div>
</div>
