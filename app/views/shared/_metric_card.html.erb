<%# locals: (titulo:, valor: "—", descripcion: nil, badge: nil) %>
<div class="card border border-base-300 bg-base-100 shadow-sm">
  <div class="card-body gap-1">
    <h2 class="text-xs font-bold uppercase tracking-widest text-steel-3"><%= titulo %></h2>
    <span class="font-display text-4xl font-bold"><%= valor %></span>
    <% if descripcion %>
      <p class="text-sm text-steel-3"><%= descripcion %></p>
    <% end %>
    <% if badge %>
      <div class="card-actions mt-1">
        <span class="badge badge-ghost badge-sm"><%= badge %></span>
      </div>
    <% end %>
  </div>
</div>
