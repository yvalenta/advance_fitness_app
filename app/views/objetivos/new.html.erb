<% content_for :title, "Fijar objetivo — Advance Fitness" %>

<%= render "shared/encabezado",
      eyebrow: "Nutrición",
      titulo: "¿Cuál es tu meta?",
      descripcion: "Con tu perfil y tu peso actual calculamos tu TDEE y el objetivo de calorías diarias." %>

<div class="mx-auto -mt-8 w-full max-w-2xl px-4 pb-12">
  <div class="card animate-fade-up border border-base-300 bg-base-100 shadow-md">
    <div class="card-body">
      <% if @objetivo.errors.any? %>
        <div role="alert" class="alert alert-error text-sm">
          <%= render "shared/icono", nombre: :alerta, clase: "size-5 shrink-0" %>
          <span><%= @objetivo.errors.full_messages.to_sentence %></span>
        </div>
      <% end %>

      <%= form_with model: @objetivo, url: objetivo_path, method: :post, class: "flex flex-col gap-5" do |form| %>
        <fieldset>
          <legend class="mb-3 text-sm font-bold">Meta</legend>
          <div class="grid gap-3 sm:grid-cols-3">
            <% [ [ "deficit", "🔻", "Bajar de peso", "Déficit de 500 kcal" ],
                 [ "mantenimiento", "⚖️", "Mantenerme", "Calorías de mantenimiento" ],
                 [ "superavit", "📈", "Ganar masa", "Superávit según somatotipo" ] ].each do |valor, emoji, nombre, detalle| %>
              <label class="card-hover flex cursor-pointer flex-col gap-1 rounded-xl border-2 border-base-300 p-4 has-checked:border-volt-d has-checked:bg-volt/10">
                <span class="flex items-center justify-between">
                  <span class="text-2xl"><%= emoji %></span>
                  <%= form.radio_button :tipo, valor, class: "radio radio-primary radio-sm",
                        checked: @objetivo.tipo == valor, required: true %>
                </span>
                <span class="font-semibold"><%= nombre %></span>
                <span class="text-xs text-steel-3"><%= detalle %></span>
              </label>
            <% end %>
          </div>
        </fieldset>

        <label class="form-control max-w-xs">
          <span class="label-text mb-1 text-xs font-semibold">Peso actual (kg)</span>
          <%= form.number_field :peso_kg, step: 0.1, min: 20, max: 399, required: true,
                placeholder: "70.5", class: "input input-bordered w-full" %>
        </label>

        <p class="text-xs text-steel-3">
          Usamos Mifflin-St Jeor con tu perfil (<%= link_to "editar", edit_perfil_path, class: "link" %>).
          Cuando llegue el módulo de biometría, el peso se tomará de tu última medición.
        </p>

        <div class="flex gap-2">
          <%= form.submit "Calcular mi objetivo", class: "btn btn-primary font-bold" %>
          <%= link_to "Cancelar", objetivo_path, class: "btn btn-ghost" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
