<% content_for :title, "Mejorar plan — Advance Fitness" %>

<%= render "shared/encabezado",
      eyebrow: "Planes",
      titulo: "Elige tu plan",
      descripcion: "El plan Personalizado se activa en recepción: el admin registra tu pago y se analiza tu plan para revisión del entrenador." %>

<div class="mx-auto -mt-8 w-full max-w-4xl px-4 pb-12">
  <div class="grid items-stretch gap-6 md:grid-cols-2">
    <% @planes.each_with_index do |plan, indice| %>
      <div class="card animate-fade-up <%= "fade-delay-#{indice}" if indice.positive? %> <%= plan.personalizado? ? "border-2 border-volt-d shadow-lg" : "border border-base-300 shadow-md" %> relative bg-base-100">
        <% if plan.personalizado? %>
          <span class="badge badge-primary absolute -top-3 left-1/2 -translate-x-1/2 font-bold">Recomendado</span>
        <% end %>
        <div class="card-body">
          <h2 class="eyebrow text-steel-3"><%= plan.nombre %></h2>
          <p class="font-display text-4xl font-bold tracking-tight">
            <%= plan.precio.zero? ? "Gratis" : cop(plan.precio) %>
            <% unless plan.precio.zero? %><span class="text-base font-normal text-steel-3">/ mes</span><% end %>
          </p>
          <ul class="mt-3 flex flex-col gap-2.5">
            <% plan.beneficios.each do |beneficio| %>
              <li class="flex items-start gap-2.5 text-sm">
                <span class="mt-0.5 flex size-5 shrink-0 items-center justify-center rounded-full <%= plan.personalizado? ? "bg-volt text-steel" : "bg-base-200 text-steel-5" %>">
                  <%= render "shared/icono", nombre: :check, clase: "size-3" %>
                </span>
                <%= beneficio %>
              </li>
            <% end %>
          </ul>
          <div class="card-actions mt-4">
            <% if plan.personalizado? %>
              <% if Current.user.premium? %>
                <span class="badge badge-success">Tu plan actual</span>
              <% else %>
                <div class="w-full rounded-xl bg-volt/10 p-3 text-center text-sm font-semibold text-volt-d">
                  Actívalo en recepción 💪
                </div>
              <% end %>
            <% elsif !Current.user.premium? %>
              <span class="badge badge-ghost">Tu plan actual</span>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
