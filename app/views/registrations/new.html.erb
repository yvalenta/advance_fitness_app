<% content_for :title, "Crear cuenta — #{Negocio.nombre}" %>

<div class="grid min-h-screen lg:grid-cols-2">
  <%= render "shared/auth_brand" %>

  <div class="flex items-center justify-center bg-base-200 px-4 py-10">
    <div class="w-full max-w-sm">
      <div class="mb-6 flex flex-col items-center gap-3 text-center lg:hidden">
        <span class="flex size-12 items-center justify-center rounded-2xl bg-steel">
          <%= render "shared/logo" %>
        </span>
        <span class="font-display text-sm font-bold tracking-[0.18em]">ADVANCE<span class="text-volt-d">FITNESS</span></span>
      </div>

      <div class="card border border-base-300 bg-base-100 shadow-xl">
        <div class="card-body gap-4">
          <div>
            <h1 class="font-display text-2xl font-bold">Crea tu cuenta</h1>
            <p class="mt-1 text-sm text-steel-5">Empieza a registrar tu progreso hoy</p>
          </div>

          <% if @user.errors.any? %>
            <div role="alert" class="alert alert-error text-sm">
              <%= render "shared/icono", nombre: :alerta, clase: "size-5 shrink-0" %>
              <span><%= @user.errors.full_messages.to_sentence %></span>
            </div>
          <% end %>

          <%= form_with model: @user, url: registro_path, class: "flex flex-col gap-3" do |form| %>
            <label class="form-control w-full">
              <span class="label-text mb-1 text-xs font-semibold">Nombre completo</span>
              <%= form.text_field :nombre, required: true, autofocus: true, autocomplete: "name",
                    placeholder: "Nombre y apellido", class: "input input-bordered w-full" %>
            </label>
            <label class="form-control w-full">
              <span class="label-text mb-1 text-xs font-semibold">Correo electrónico</span>
              <%= form.email_field :email_address, required: true, autocomplete: "username",
                    placeholder: "tu@correo.com", class: "input input-bordered w-full" %>
            </label>
            <label class="form-control w-full">
              <span class="label-text mb-1 text-xs font-semibold">Contraseña</span>
              <%= form.password_field :password, required: true, autocomplete: "new-password",
                    placeholder: "Mínimo 8 caracteres", minlength: 8, maxlength: 72, class: "input input-bordered w-full" %>
            </label>
            <label class="form-control w-full">
              <span class="label-text mb-1 text-xs font-semibold">Confirma tu contraseña</span>
              <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password",
                    placeholder: "Repite la contraseña", maxlength: 72, class: "input input-bordered w-full" %>
            </label>
            <%= form.submit "Crear cuenta", class: "btn btn-primary w-full font-bold" %>
          <% end %>

          <div class="text-center text-sm text-steel-5">
            ¿Ya tienes cuenta? <%= link_to "Inicia sesión", new_session_path, class: "link link-hover font-semibold text-volt-d" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
