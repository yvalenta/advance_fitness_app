<% content_for :title, "Dashboard — Advance Fitness" %>

<div class="mx-auto max-w-6xl px-4 py-8">
  <div class="mb-6">
    <h1 class="font-display text-2xl font-bold">
      Hola, <%= Current.user.nombre.presence || Current.user.email_address %> 👋
    </h1>
    <p class="text-sm text-steel-3">Miembro desde <%= l Current.user.fecha_ingreso, format: :long %></p>
  </div>

  <div class="grid gap-4 sm:grid-cols-3">
    <% if @membresia %>
      <%= render "shared/metric_card",
            titulo: "Membresía",
            valor: "#{@membresia.dias_restantes} días",
            descripcion: "Vence el #{l @membresia.fecha_vencimiento, format: :long}",
            badge: @membresia.estado %>
    <% else %>
      <%= render "shared/metric_card",
            titulo: "Membresía",
            valor: "—",
            descripcion: "Acércate a recepción para activar tu membresía",
            badge: "sin membresía" %>
    <% end %>
    <%= render "shared/metric_card",
          titulo: "Biometría",
          valor: "—",
          descripcion: "Peso, IMC y progreso mensual",
          badge: "Disponible en Fase 3" %>
    <%= render "shared/metric_card",
          titulo: "Calorías",
          valor: "—",
          descripcion: "Objetivo diario y consumo",
          badge: "Disponible en Fase 4" %>
  </div>
</div>
