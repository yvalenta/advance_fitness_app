# Google OAuth — Google Cloud Console → Auth Platform → Clientes
# Redirect URI: http://localhost:3000/auth/google_oauth2/callback
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx

# Dentro de Docker (dip) la base la define docker-compose.yml.
# DATABASE_URL solo aplica fuera de los contenedores (p. ej. producción).
# DATABASE_URL=

# IA — GenerarPlanJob (Fase 5). Solo server-side, jamás en vistas.
# Proveedor activo: gemini (default) o claude. Cambiar requiere reiniciar
# el contenedor (dip compose restart web). Keys alternativas: Rails
# credentials (gemini_api_key / anthropic_api_key).
IA_PROVEEDOR=gemini
GEMINI_API_KEY=AIzaxxxxxxxx
# GEMINI_MODELO=gemini-2.5-flash
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# CLAUDE_MODELO=claude-sonnet-5
