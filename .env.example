# Google OAuth — Google Cloud Console → Auth Platform → Clientes
# Redirect URI: http://localhost:3000/auth/google_oauth2/callback
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx

# Dentro de Docker (dip) la base la define docker-compose.yml.
# DATABASE_URL solo aplica fuera de los contenedores (p. ej. producción).
# DATABASE_URL=
