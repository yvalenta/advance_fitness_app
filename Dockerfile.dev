# Imagen de DESARROLLO — la de producción es ./Dockerfile (Kamal).
# Se usa vía docker-compose + dip (dip provision, dip rails s, dip test…).

ARG RUBY_VERSION=4.0.5
FROM docker.io/library/ruby:$RUBY_VERSION-slim

WORKDIR /rails

RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      build-essential git curl pkg-config \
      libpq-dev postgresql-client \
      libvips libyaml-dev libjemalloc2 && \
    rm -rf /var/lib/apt/lists /var/cache/apt/archives

ENV LD_PRELOAD="/usr/lib/aarch64-linux-gnu/libjemalloc.so.2" \
    BUNDLE_PATH="/usr/local/bundle"

# Las gemas viven en el volumen `bundle` del compose y se instalan con
# `dip bundle install` (parte de `dip provision`), no en la imagen:
# así cambiar el Gemfile no obliga a reconstruir.

EXPOSE 3000

CMD ["bin/dev"]
